# ─── OpenAI API ───────────────────────────────────────────────────────────────
# OpenAI platformundan al: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-buraya-openai-api-keyini-yapistir

# ─── Veritabanı Ayarları ──────────────────────────────────────────────────────
# Geliştirme için SQLite kullan (true = SQLite, false = PostgreSQL)
USE_SQLITE=true
SQLITE_PATH=genai_gateway.db

# PostgreSQL bilgileri (USE_SQLITE=false ise geçerli)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=genai_gateway
DB_USER=postgres
DB_PASSWORD=sifren_buraya

# ─── DeBERTa Model Ayarları ───────────────────────────────────────────────────
# protectai/deberta-v3-base-prompt-injection-v2 — Hugging Face'den otomatik indirilir
# İlk çalıştırmada internet bağlantısı gerekir (~500MB)
